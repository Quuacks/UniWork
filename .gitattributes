# Ignore SWIG interface files
*.i linguist-vendored

# Ignore generated wrapper code (common naming patterns)
*_wrap.c linguist-generated
*_wrap.cxx linguist-generated
*_wrap.cpp linguist-generated

# Optional: if you have a bindings or generated folder
bindings/** linguist-generated
generated/** linguist-generated

# Ensure C files are counted normally
*.c linguist-language=C
